PORT=3000
# Interval (ms) at which the live match simulation engine advances matches
# and broadcasts updates. The public "live scores" contract is a 15s cadence.
LIVE_TICK_INTERVAL_MS=15000
# Default IANA timezone used when a client does not specify ?tz=
DEFAULT_TIMEZONE=UTC
# Default language code used when a client does not specify ?lang= or Accept-Language
DEFAULT_LANGUAGE=en
